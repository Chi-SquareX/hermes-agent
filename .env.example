# Copy to .env and fill in your Google Cloud OAuth credentials.
# Never commit .env — it stays on your machine only.

GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# Must match the port the dashboard listens on (see HERMES_PORT below).
GOOGLE_REDIRECT_URI=http://localhost:8010/auth/callback

# Dashboard port (used by app.py, Docker, and restart_dashboard.py).
HERMES_PORT=8010

# Optional: auto-shutdown the OAuth server after N seconds (0 = disabled).
AUTO_KILL_AFTER_SECONDS=0

# LinkedIn automation safety throttles (optional).
# Minimum delay between LinkedIn actions.
LINKEDIN_MIN_ACTION_GAP_SECONDS=4.0
# Random jitter range added to action pacing.
LINKEDIN_JITTER_MIN_SECONDS=0.6
LINKEDIN_JITTER_MAX_SECONDS=1.8
# Global action cap and mutating-action cap.
LINKEDIN_MAX_ACTIONS_PER_MINUTE=12
LINKEDIN_MAX_MUTATING_ACTIONS_PER_HOUR=20
# Cooldown after checkpoint/challenge/captcha detection.
LINKEDIN_DETECTION_BACKOFF_SECONDS=900
